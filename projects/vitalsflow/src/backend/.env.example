# Copy this file to .env and fill in real values.
# Never commit .env — it is listed in .gitignore.

# ── Gemini ───────────────────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override model (default is models/gemini-2.0-flash)
# GEMINI_MODEL=models/gemini-2.0-flash

# ── Groq fallback (Llama 3.3 70B) ───────────────────────────────────────────
# Get your key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: override Groq fallback model
# GROQ_MODEL=llama-3.3-70b-versatile

# Set to false to skip LLM and run deterministic NEWS2 only (useful for dev)
# USE_LLM=true

# ── FHIR ─────────────────────────────────────────────────────────────────────
# Public HAPI FHIR R4 server — no auth required for hackathon
FHIR_BASE_URL=http://hapi.fhir.org/baseR4

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# CORS_ORIGINS=http://localhost:3000,https://vitalsflow.vercel.app

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
